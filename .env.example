# ============================================================
# VARIÁVEIS DE AMBIENTE — REINO DAS CORES (Template PLR)
# ============================================================
# Copie este arquivo para .env e preencha com os dados do
# SEU projeto Supabase: https://app.supabase.com/project/_/settings/api
# ============================================================

# URL e chave pública do projeto Supabase (visíveis no bundle — seguro)
VITE_SUPABASE_URL=https://SEU-PROJECT-ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...anon-key-aqui

# Service Role Key — APENAS server-side, NUNCA expor no cliente
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key-aqui

# OG Image para redes sociais (opcional)
# VITE_OG_IMAGE_URL=https://seu-cdn.com/og-image.png
